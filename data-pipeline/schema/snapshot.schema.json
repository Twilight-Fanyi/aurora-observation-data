{
  "$id": "https://aurora.local/schema/snapshot.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "sources", "locations"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "pattern": "Z$" },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kp", "solarWind", "ovation", "weather"],
      "properties": {
        "kp": { "$ref": "#/$defs/sourceStatus" },
        "solarWind": { "$ref": "#/$defs/sourceStatus" },
        "ovation": { "$ref": "#/$defs/sourceStatus" },
        "weather": { "$ref": "#/$defs/sourceStatus" }
      }
    },
    "locations": {
      "type": "array",
      "minItems": 50,
      "maxItems": 50,
      "items": { "$ref": "#/$defs/location" }
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "pattern": "Z$"
    },
    "sourceStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observedAt", "status"],
      "properties": {
        "observedAt": { "$ref": "#/$defs/timestamp" },
        "status": { "enum": ["fresh", "reused"] }
      }
    },
    "reasonCode": {
      "enum": [
        "dark_now",
        "high_cloud",
        "southward_bz",
        "kp_below_reference",
        "low_ovation",
        "clear_sky",
        "daylight"
      ]
    },
    "current": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "level",
        "confidence",
        "kp",
        "bzGsm",
        "solarWindKmS",
        "ovation",
        "ovationDistanceDegrees",
        "cloudCover",
        "visibilityKm",
        "solarElevation",
        "reasonCodes"
      ],
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "level": { "enum": ["quiet", "faint", "active", "storm"] },
        "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
        "kp": { "type": "number", "minimum": 0, "maximum": 9 },
        "bzGsm": { "type": "number", "minimum": -100, "maximum": 100 },
        "solarWindKmS": { "type": "number", "minimum": 0, "maximum": 5000 },
        "ovation": { "type": "number", "minimum": 0, "maximum": 100 },
        "ovationDistanceDegrees": { "type": "number", "minimum": 0, "maximum": 180 },
        "cloudCover": { "type": "number", "minimum": 0, "maximum": 100 },
        "visibilityKm": { "type": "number", "minimum": 0, "maximum": 1000 },
        "solarElevation": { "type": "number", "minimum": -90, "maximum": 90 },
        "reasonCodes": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/reasonCode" }
        }
      }
    },
    "hourly": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeUtc",
        "localTime",
        "score",
        "kp",
        "cloudCover",
        "visibilityKm",
        "darkness",
        "confidence"
      ],
      "properties": {
        "timeUtc": { "$ref": "#/$defs/timestamp" },
        "localTime": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "kp": { "type": "number", "minimum": 0, "maximum": 9 },
        "cloudCover": { "type": "number", "minimum": 0, "maximum": 100 },
        "visibilityKm": { "type": "number", "minimum": 0, "maximum": 1000 },
        "darkness": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "bestWindow": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["startUtc", "endUtc"],
          "properties": {
            "startUtc": { "$ref": "#/$defs/timestamp" },
            "endUtc": { "$ref": "#/$defs/timestamp" }
          }
        }
      ]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "localTimeZone", "current", "hourly", "bestWindow"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "localTimeZone": { "type": "string", "minLength": 1 },
        "current": { "$ref": "#/$defs/current" },
        "hourly": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/hourly" }
        },
        "bestWindow": { "$ref": "#/$defs/bestWindow" }
      }
    }
  }
}
